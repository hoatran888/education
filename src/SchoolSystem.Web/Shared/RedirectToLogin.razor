@inject NavigationManager Navigation
@inject IConfiguration    Configuration

@code {
    protected override void OnInitialized()
    {
        var clientId    = Configuration["AzureAd:ClientId"];
        var isRealEntra = Guid.TryParse(clientId, out var id) && id != Guid.Empty;

        var returnUrl = Uri.EscapeDataString(Navigation.Uri);

        if (isRealEntra)
            Navigation.NavigateTo($"MicrosoftIdentity/Account/SignIn?returnUrl={returnUrl}", forceLoad: true);
        else
            Navigation.NavigateTo($"/account/login?returnUrl={returnUrl}", forceLoad: true);
    }
}
