@inherits LayoutComponentBase
@inject IConfiguration Configuration

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">School Management System</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-2">@context.User.Identity?.Name</MudText>
                @if (_isDevMode)
                {
                    <MudButton Href="/account/logout"
                               Variant="Variant.Text" Color="Color.Inherit">Sign Out</MudButton>
                }
                else
                {
                    <MudButton Href="MicrosoftIdentity/Account/SignOut"
                               Variant="Variant.Text" Color="Color.Inherit">Sign Out</MudButton>
                }
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4 mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    bool _isDevMode;

    protected override void OnInitialized()
    {
        var b2cClientId = Configuration["AzureAdB2C:ClientId"];
        _isDevMode = string.IsNullOrWhiteSpace(b2cClientId)
                  || b2cClientId == "00000000-0000-0000-0000-000000000000";
    }

    void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
